{% extends '@SyliusAdmin/shared/layout/base.html.twig' %}

{% block title %}Восстановление картинок | {{ parent() }}{% endblock %}

{% block body %}
<div class="container-xl my-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-9">
            <div class="mb-3">
                <a href="{{ path('sylius_admin_dashboard') }}" class="text-secondary">
                    {{ ux_icon('tabler:arrow-left') }} Панель управления
                </a>
            </div>

            <div class="alert alert-success">
                {{ ux_icon('tabler:photo-up') }}
                Восстановлено файлов: <strong>{{ report.restored }}</strong>.
            </div>

            {% if report.skipped is not empty %}
                <div class="card mb-3">
                    <div class="card-header">
                        <h3 class="card-title">{{ ux_icon('tabler:file-off') }} Пропущенные файлы ({{ report.skipped|length }})</h3>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table">
                            <thead><tr><th>Файл</th><th>Причина</th></tr></thead>
                            <tbody>
                                {% for s in report.skipped %}
                                    <tr>
                                        <td><code>{{ s.entry }}</code></td>
                                        <td class="text-secondary">{{ s.reason }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">{{ ux_icon('tabler:photo-search') }} Целостность картинок после восстановления</h3>
                </div>
                <div class="card-body">
                    {% include 'admin/tools/_missing_images.html.twig' %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
