{% set user_id = resource.id|default(data.id|default(null)) %}
{% if user_id is not null %}
    {% set modal_id = 'change-password-' ~ user_id %}
    <button type="button" class="btn" data-bs-toggle="modal" data-bs-target="#{{ modal_id }}">Сменить пароль</button>

    <div class="modal fade" id="{{ modal_id }}" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Смена пароля — {{ resource.name|default(data.name|default('')) }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Новый пароль</label>
                        <input type="password" class="form-control js-change-password-input" minlength="6" required>
                    </div>
                    <div class="js-change-password-error text-danger" style="display:none;"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary js-change-password-submit">Сохранить</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            const modalEl = document.getElementById({{ modal_id|json_encode|raw }});
            const input = modalEl.querySelector('.js-change-password-input');
            const errorEl = modalEl.querySelector('.js-change-password-error');
            const submitBtn = modalEl.querySelector('.js-change-password-submit');

            modalEl.addEventListener('shown.bs.modal', function() {
                input.value = '';
                errorEl.style.display = 'none';
                input.focus();
            });

            submitBtn.addEventListener('click', function() {
                const password = input.value;
                errorEl.style.display = 'none';

                if (password.length < 6) {
                    errorEl.textContent = 'Пароль должен содержать минимум 6 символов';
                    errorEl.style.display = 'block';
                    return;
                }

                submitBtn.disabled = true;
                fetch({{ path('app_admin_user_change_password', {id: user_id})|json_encode|raw }}, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ password: password })
                })
                    .then(function(r) { return r.json().then(function(data) { return { ok: r.ok, data: data }; }); })
                    .then(function(result) {
                        if (!result.ok || !result.data.success) {
                            errorEl.textContent = (result.data && result.data.error) || 'Не удалось изменить пароль';
                            errorEl.style.display = 'block';
                            return;
                        }
                        bootstrap.Modal.getOrCreateInstance(modalEl).hide();
                    })
                    .catch(function() {
                        errorEl.textContent = 'Ошибка сети';
                        errorEl.style.display = 'block';
                    })
                    .finally(function() {
                        submitBtn.disabled = false;
                    });
            });
        })();
    </script>
{% endif %}
